{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "violet",
      "camelcase": "Violet",
      "scope": "source.violet",
      "path": ".",
      "file-types": [
        "vt"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^violet$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Violet grammar for tree-sitter",
    "authors": [
      {
        "name": "dannypsnl"
      }
    ]
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
